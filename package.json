  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate:sql": "node scripts/apply-sql-migration.mjs drizzle/migrations/0001_multi_tenant_scaffold.sql",
    "db:migrate:screen-quotes": "node scripts/apply-sql-migration.mjs drizzle/migrations/0043_security_screen_quote_item_detail_columns.sql",
    "db:migrate:blinds": "node scripts/apply-sql-migration.mjs drizzle/migrations/0047_blinds_quotes.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0048_blinds_supplier_csv_data.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0049_blinds_fabric_colours.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0050_blinds_fabric_colour_seed.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0051_blinds_fabric_swatch_urls.sql",
    "db:migrate:inbox": "node scripts/apply-sql-migration.mjs drizzle/migrations/0035_inbox_tickets.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0036_inbox_ticket_column_compat.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0037_inbox_address_module_varchar.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0044_inbox_ticket_lifecycle_notes.sql && node scripts/apply-sql-migration.mjs drizzle/migrations/0045_inbox_sla_templates_presence_threading.sql",
