    "db:migrate:tenant-scope": "node scripts/apply-sql-migration.mjs drizzle/migrations/0052_tenant_library_whs_scope.sql",
    "db:migrate:tenant-private-scope": "node scripts/apply-sql-migration.mjs drizzle/migrations/0053_tenant_private_admin_scope.sql",
    "scheduled:dispatch": "node scripts/scheduled-dispatcher.mjs",
    "tenant:repair:dry-run": "node scripts/run-tenant-repair.mjs --dry-run",
    "tenant:repair:apply": "node scripts/run-tenant-repair.mjs --apply"
